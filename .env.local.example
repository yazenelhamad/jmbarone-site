# Copy to .env.local and fill in your Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public site URL (used for sitemap/SEO/redirects)
NEXT_PUBLIC_SITE_URL=https://jmbaroneinc.com

# Formspree — contact form email delivery (optional but recommended).
# Sign up at https://formspree.io, create a form, copy the form ID
# (the slug after /f/ in your endpoint URL — e.g. "xqkraowe") here.
FORMSPREE_FORM_ID=

